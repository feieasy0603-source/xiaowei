# =============================================================================
# Docker Compose 环境变量 — 复制为 .env 后修改
# 用法: cp .env.example .env && docker compose up -d --build
# 本地演示可将 PAYMENT_MOCK_ENABLED=true（无需真实商户号）
# =============================================================================

# --- MySQL ---
MYSQL_ROOT_PASSWORD=change-me-strong-password
MYSQL_PASSWORD=change-me-strong-password
MYSQL_USER=root
MYSQL_DB=xiaowei

# --- 后端密钥（生产务必更换）---
JWT_SECRET=change-me-use-openssl-rand-base64-32-min-32-chars
PAY_CALLBACK_SECRET=change-me-pay-callback-secret-32chars

# --- 支付 ---
# 生产 false；本地 Docker 演示可 true
PAYMENT_MOCK_ENABLED=false

# --- 分享 ---
REFERRAL_FRONTEND_BASE_URL=http://localhost/

# --- 限流 ---
XIAOWEI_RATE_LIMIT_LOOKUP_MAX=30

# --- CORS（Compose 同域反代通常留空）---
# CORS_ALLOWED_ORIGINS=

# =============================================================================
# 微信支付 Native（PAYMENT_MOCK_ENABLED=false 且需扫码收款时配置）
# =============================================================================
WECHAT_PAY_ENABLED=false
# WECHAT_APP_ID=
# WECHAT_MCH_ID=
# WECHAT_API_V3_KEY=
# WECHAT_SERIAL_NO=
# WECHAT_PRIVATE_KEY_PEM=
# WECHAT_NOTIFY_URL=http://localhost/api/payments/callback/wechat

# =============================================================================
# 支付宝当面付（扫码）
# 沙箱: ALIPAY_APP_ID=9021000164658513
#       ALIPAY_GATEWAY_URL=https://openapi-sandbox.dl.alipaydev.com/gateway.do
# =============================================================================
ALIPAY_PAY_ENABLED=false
# ALIPAY_APP_ID=
# ALIPAY_PRIVATE_KEY_PEM=
# ALIPAY_PUBLIC_KEY_PEM=
ALIPAY_GATEWAY_URL=https://openapi.alipay.com/gateway.do
# ALIPAY_NOTIFY_URL=http://localhost/api/payments/callback/alipay

# PEM 单行写法示例（Docker .env 推荐）:
# ALIPAY_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----"
