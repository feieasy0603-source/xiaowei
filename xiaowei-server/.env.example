# =============================================================================
# xiaowei-server 本地开发环境变量
# 用法: cp .env.example .env 后修改（Spring 自动 import optional:file:.env）
# 沙箱联调支付宝: cp .env.sandbox.example .env
# 生产部署参考: .env.production.example
# =============================================================================

# --- 基础 ---
SPRING_PROFILES_ACTIVE=dev,mysql
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=xiaowei
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password

JWT_SECRET=xiaowei-dev-secret-change-in-production-min-32-chars
STORAGE_DIR=./data/uploads
STORAGE_MAX_UPLOAD_BYTES=20971520

# --- 认证 / 演示 ---
AUTH_DEMO_ENABLED=false

# --- 支付（通用）---
# 开发 mock 回调鉴权头 X-Pay-Secret
PAY_CALLBACK_SECRET=xiaowei-pay-dev-secret
# true=允许模拟扫码；接真实微信/支付宝时改为 false
PAYMENT_MOCK_ENABLED=false

# --- 微信支付 Native（可选）---
# notify 走 POST /api/payments/callback/wechat（V3 协议）
WECHAT_PAY_ENABLED=false
# WECHAT_APP_ID=
# WECHAT_MCH_ID=
# WECHAT_API_V3_KEY=              # 32 字节 APIv3 密钥
# WECHAT_SERIAL_NO=               # 商户证书序列号
# WECHAT_PRIVATE_KEY_PEM=         # 商户私钥 PEM（PKCS8）
# WECHAT_NOTIFY_URL=https://你的域名/api/payments/callback/wechat

# --- 支付宝当面付 / 扫码（可选）---
# notify 走 POST /api/payments/callback/alipay（form-urlencoded，返回 success）
ALIPAY_PAY_ENABLED=false
# ALIPAY_APP_ID=
# ALIPAY_PRIVATE_KEY_PEM=         # 应用私钥 PKCS8 PEM
# ALIPAY_PUBLIC_KEY_PEM=          # 支付宝公钥 PEM（开放平台「支付宝公钥」，非应用公钥）
# 正式网关（默认）:
# ALIPAY_GATEWAY_URL=https://openapi.alipay.com/gateway.do
# 沙箱网关:
# ALIPAY_GATEWAY_URL=https://openapi-sandbox.dl.alipaydev.com/gateway.do
# ALIPAY_NOTIFY_URL=https://你的公网HTTPS/api/payments/callback/alipay
# 本地调试 notify 需 ngrok/cpolar 等内网穿透

# --- 钱包 ---
# 禁止用户直接 POST /wallet/recharge 加余额（须走 prepay + 回调）
XIAOWEI_WALLET_ALLOW_DIRECT_RECHARGE=false

# --- 邀请分享 ---
# REFERRAL_INVITER_REWARD=5.00
# REFERRAL_INVITEE_REWARD=2.00
REFERRAL_FRONTEND_BASE_URL=http://localhost:5173/

# --- CORS（生产前后端分域时设置，逗号分隔；同域 Nginx 反代可留空）---
# CORS_ALLOWED_ORIGINS=https://你的域名,https://你的域名/admin

# --- 限流 ---
# XIAOWEI_RATE_LIMIT_LOOKUP_MAX=30

# --- 在线客服 ---
# SUPPORT_PHONE=
# SUPPORT_WECHAT_ID=

# --- 文献检索 ---
# LITERATURE_OPENALEX_ENABLED=true
# LITERATURE_OPENALEX_MIN_LOCAL=8

# --- AI（运行时以管理端 DB 配置为准，YAML 为默认值）---
XIAOWEI_AI_MOCK=false
XIAOWEI_AI_ALLOW_MOCK=false
XIAOWEI_AI_PROVIDER=openai
XIAOWEI_AI_MODEL_NAME=gpt-4o-mini
# XIAOWEI_AI_BASE_URL=

# =============================================================================
# PEM 密钥写法（微信/支付宝私钥、支付宝公钥均适用）任选其一:
#
# 1) 双引号 + 真实换行:
# ALIPAY_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----
# MIIEvQIBADANBg...
# -----END PRIVATE KEY-----"
#
# 2) 单行 \n 转义（Docker .env 常用）:
# ALIPAY_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----"
# =============================================================================
