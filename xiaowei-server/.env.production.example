# =============================================================================
# xiaowei-server 生产环境 — 复制为 .env 或在启动前 export
# 配合 SPRING_PROFILES_ACTIVE=prod,mysql 与 application-prod.yml
# 生成随机密钥: openssl rand -base64 32
# =============================================================================

SPRING_PROFILES_ACTIVE=prod,mysql
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=xiaowei
MYSQL_USER=root
MYSQL_PASSWORD=

JWT_SECRET=请替换为至少32字符随机串
PAY_CALLBACK_SECRET=请替换为支付回调密钥
PAYMENT_MOCK_ENABLED=false

STORAGE_DIR=./data/uploads
STORAGE_MAX_UPLOAD_BYTES=20971520
AUTH_DEMO_ENABLED=false
XIAOWEI_AI_MOCK=false
XIAOWEI_AI_ALLOW_MOCK=false

# --- 邀请分享（管理后台可覆盖 DB 配置）---
REFERRAL_FRONTEND_BASE_URL=https://你的域名/
# REFERRAL_INVITER_REWARD=5.00
# REFERRAL_INVITEE_REWARD=2.00

# --- CORS（前后端同域 Nginx 反代时可留空）---
# CORS_ALLOWED_ORIGINS=https://你的域名,https://你的域名/admin

# --- 限流 ---
XIAOWEI_RATE_LIMIT_LOOKUP_MAX=30

# --- 在线客服 ---
# SUPPORT_PHONE=
# SUPPORT_WECHAT_ID=

# --- 文献检索 ---
# LITERATURE_OPENALEX_ENABLED=true
# LITERATURE_OPENALEX_MIN_LOCAL=8

# =============================================================================
# 微信支付 Native（可选，至少启用微信或支付宝之一，或仅用余额/礼包码）
# =============================================================================
WECHAT_PAY_ENABLED=false
# WECHAT_APP_ID=
# WECHAT_MCH_ID=
# WECHAT_API_V3_KEY=              # 32 字节
# WECHAT_SERIAL_NO=
# WECHAT_PRIVATE_KEY_PEM=
# WECHAT_NOTIFY_URL=https://你的域名/api/payments/callback/wechat

# =============================================================================
# 支付宝当面付 / 扫码（可选）
# 开放平台签约「当面付」→ 上传应用公钥 → 保存支付宝公钥
# =============================================================================
ALIPAY_PAY_ENABLED=false
# ALIPAY_APP_ID=
# ALIPAY_PRIVATE_KEY_PEM=
# ALIPAY_PUBLIC_KEY_PEM=
ALIPAY_GATEWAY_URL=https://openapi.alipay.com/gateway.do
# ALIPAY_NOTIFY_URL=https://你的域名/api/payments/callback/alipay

# --- 钱包 ---
XIAOWEI_WALLET_ALLOW_DIRECT_RECHARGE=false

# =============================================================================
# 回调地址说明（须 HTTPS 公网可达，路径含 context-path /api）:
#   微信: https://域名/api/payments/callback/wechat
#   支付宝: https://域名/api/payments/callback/alipay
# 授权回调地址（OAuth）与上述异步通知无关，纯扫码支付可不填
# =============================================================================
